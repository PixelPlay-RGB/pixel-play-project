# PixelPlay 자동 방송 썸네일 캡처 — /etc/systemd/system/pixelplay-live-thumbnail.service
[Unit]
Description=PixelPlay live auto-thumbnail capture push
After=network-online.target docker.service

[Service]
Type=oneshot
User=ubuntu
EnvironmentFile=/etc/pixelplay/live-thumbnail.env
ExecStart=/usr/bin/python3 /opt/pixelplay/live-thumbnail-push.py
