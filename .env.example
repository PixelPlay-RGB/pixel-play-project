# ENV 파일에 새로운 환경 변수를 추가하면 env.d.ts에 타입 정의를 해주셔야 자동완성이 됩니다!!

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000/
NEXT_PUBLIC_ENABLE_REACT_QUERY_DEVTOOLS=false
NEXT_PUBLIC_TOSS_PAYMENTS_CLIENT_KEY=

# 서버 전용. 클라이언트 번들이나 NEXT_PUBLIC_*로 노출하지 마세요.
TOSS_PAYMENTS_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=
LIVE_OVERLAY_TOKEN_SECRET=

# 라이브 송출(MediaMTX). 미설정 시 live.pixel-play.studio 기본값을 사용합니다.
# NEXT_PUBLIC_* 3개는 클라이언트 노출, MEDIAMTX_API_BASE_URL과 MEDIAMTX_HOOK_SECRET은 서버 전용.
NEXT_PUBLIC_MEDIAMTX_RTMP_SERVER_URL=rtmp://live.pixel-play.studio/live
NEXT_PUBLIC_MEDIAMTX_HLS_BASE_URL=https://live.pixel-play.studio:8888
NEXT_PUBLIC_MEDIAMTX_STREAM_PATH=
MEDIAMTX_API_BASE_URL=http://live.pixel-play.studio:9997

GOOGLE_CLOUD_TTS_API_KEY=
GEMINI_API_KEY=